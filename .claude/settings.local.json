      "PowerShell(Get-Process | Where-Object {$_.ProcessName -match 'watchdog|mcp' -or $_.MainWindowTitle -match 'watchdog|mcp'} | Select-Object Id, ProcessName, MainWindowTitle)",
      "PowerShell([System.TimeZoneInfo]::ConvertTimeBySystemTimeZoneId\\([DateTime]::UtcNow, \"Eastern Standard Time\"\\).ToString\\(\"yyyy-MM-dd HH:mm:ss\"\\) + \" ET; Local: \" + [DateTime]::Now.ToString\\(\"yyyy-MM-dd HH:mm:ss\"\\)、)"
    ]
  }
}
